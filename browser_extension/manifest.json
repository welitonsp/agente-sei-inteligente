{
  "manifest_version": 3,
  "name": "Agente SEI 19 CRPM",
  "version": "0.1.0",
  "description": "Assistente read-only do 19 CRPM dentro da tela do SEI.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://sei.go.gov.br/sei/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sei.go.gov.br/sei/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Agente SEI 19 CRPM"
  }
}
