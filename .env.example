# Aplicacao
APP_NAME="Agente SEI Inteligente - 19 CRPM"
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
TIMEZONE=America/Sao_Paulo

# Banco de dados
DATABASE_URL=sqlite:///./data/agente_sei.db

# Google Agenda
GOOGLE_CALENDAR_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
OFFICERS_GROUP_EMAIL=
DEFAULT_CALENDAR_NAME="SEI 19 CRPM - Oficiais"

# E-mail institucional
EMAIL_PROVIDER=imap
EMAIL_HOST=
EMAIL_PORT=993
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FOLDER_INBOX=INBOX
EMAIL_FOLDER_PROCESSED=Processados

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SEI
SEI_BASE_URL=https://sei.go.gov.br/sei/
SEI_MODE=assistido
SEI_OFFICIAL_MODULE_AVAILABLE=false
SEI_INTEGRATION_STRATEGY=external_local_assisted
SEI_ALLOW_WRITE_DRAFTS=false
SEI_STORE_PASSWORDS=false
SEI_ALLOW_SHARED_ACCOUNT=false
SEI_DATA_MODE=local_only
SEI_TEXT_RETENTION=ephemeral
SEI_ALLOW_EXTERNAL_AI_FOR_LIVE_CONTENT=false
SEI_ALLOW_BROWSER_EXTENSION=false

# IA
AI_PROVIDER=
AI_MODEL=
AI_API_KEY=
AI_LOCAL_ENDPOINT=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_FILE_SEARCH_STORE_SEI=

# Seguranca e auditoria
LOG_LEVEL=INFO
AUDIT_LOG_RETENTION_DAYS=365
ALLOW_OFFICIAL_SEI_ACTIONS=false
